# Staging environment variables
# This file contains ONLY non-secret placeholder values.
# Never add real passwords, tokens, or production credentials here.

APP_ENV=staging
APP_HOST=127.0.0.1
APP_PORT=8090
BASE_URL=http://127.0.0.1:8090
DATABASE_PATH=/opt/ai-starter-community/staging/data/ai_starter_community.sqlite3
SESSION_COOKIE_NAME=ai_starter_community_staging_session
SESSION_COOKIE_SECURE=false
EMAIL_MODE=outbox
EMAIL_VERIFICATION_TOKEN_EXPIRY_HOURS=24
PASSWORD_RESET_TOKEN_EXPIRY_MINUTES=30
